# LLM API (OpenAI-compatible: OpenAI, Azure, local inference servers, etc.)
API_URL=https://api.openai.com/v1
API_KEY=your-api-key-here

# Optional: folder path containing local papers (PDF/text). Default: ./papers
PAPERS_PATH=./papers

# Optional: model name (e.g. gpt-4, gpt-3.5-turbo)
MODEL_NAME=gpt-4o-mini
