# LLM API (OpenAI-compatible)
API_URL=https://api.openai.com/v1
API_KEY=your-api-key-here
MODEL_NAME=gpt-4o-mini

# Comma-separated list of models shown in the web dropdown (optional)
MODEL_LIST=gpt-4o-mini,gpt-4o,gpt-4-turbo,gpt-4,gpt-3.5-turbo

# Optional: folder for local papers (default: ./papers)
PAPERS_PATH=./papers

# Optional: folder for stored chat sessions (default: ./data)
DATA_DIR=./data

# Optional: path to MCP servers config (default: config/mcp_servers.json). Enable with pip install langchain-mcp-adapters
# MCP_SERVERS_FILE=config/mcp_servers.json

# Optional: directory of skills (default: ./skills). Each subfolder with skill.yaml adds system-prompt text.
# SKILLS_DIR=skills
